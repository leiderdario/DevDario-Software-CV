# Copia este archivo a .env.local y reemplaza los valores reales.
# .env.local NO se commitea (está en .gitignore).

# Formspree endpoint para el contact form.
# Crea uno en https://formspree.io/forms (free tier: 50 envíos/mes).
# Después de crearlo verás un endpoint tipo https://formspree.io/f/abcd1234
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/REPLACE_ME
