# Copia este archivo a .env.local y reemplaza los valores reales.
# .env.local NO se commitea (está en .gitignore).

# Formspree endpoint para el contact form.
# El endpoint actual (mnjrwljb) está hardcodeado como fallback en ContactForm.tsx,
# así que esta variable solo se necesita si quieres APUNTAR a otro form (por ejemplo,
# uno de staging). Para producción no es necesaria.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/mnjrwljb
